# ==============================================================================
# CORE PRINCIPLE
# ==============================================================================
# .env is bootstrap runtime topology, not business behavior.
# Meaning lives in MarketContext, SearchProfile, Demand Intelligence, and Decision layers.

# ==============================================================================
# 1. APP IDENTITY LAYER
# ==============================================================================
# Who this runtime is and what canonical identity it binds to.
APP_NAME=Meanly
APP_ENV=local
APP_KEY=
APP_URL=https://meanly.test
APP_DOMAIN=meanly.test
APP_PRODUCTION_DOMAIN=meanly.one

# ==============================================================================
# 2. DOMAIN & MARKET TOPOLOGY LAYER
# ==============================================================================
# Domains are aliases for semantic market contexts. They are not separate systems.
APP_PUBLIC_DOMAINS=meanly.test,meanly.one,www.meanly.one,marketplace.one,www.marketplace.one,meanly.ar,meanly.ru,www.meanly.ru,digitienda.ar,www.digitienda.ar,tsipruli.ge,www.tsipruli.ge

MARKET_DEFAULT=global
MARKET_GLOBAL_DOMAINS=meanly.test,meanly.one,www.meanly.one,marketplace.one,www.marketplace.one
MARKET_LATAM_AR_DOMAINS=meanly.ar,ar.marketplace.one,digitienda.ar,www.digitienda.ar
MARKET_RU_DOMAINS=meanly.ru,www.meanly.ru,ru.marketplace.one
MARKET_GE_DOMAINS=tsipruli.ge,www.tsipruli.ge

# Optional panel hosts. Empty means panels run on any allowed public host.
# ADMIN_PANEL_DOMAIN=
# PARTNER_PANEL_DOMAIN=

# ==============================================================================
# 3. RUNTIME EXECUTION LAYER
# ==============================================================================
# Runtime execution defaults. These do not define domain meaning.
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_SUPPORTED_LOCALES=en,ru,es,ka
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================================================
# 4. STATE LAYER
# ==============================================================================
# Infrastructure state. Keep sessions domain-local unless cross-domain cookies are intentional.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# ==============================================================================
# 5. DATA LAYER
# ==============================================================================
# Physical storage for facts. This is separate from semantic interpretation.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=marketplace
DB_USERNAME=root
DB_PASSWORD=

# Optional legacy/import databases.
# DB_HOST_PS_PLUS=127.0.0.1
# DB_PORT_PS_PLUS=3306
# DB_DATABASE_PS_PLUS=
# DB_USERNAME_PS_PLUS=
# DB_PASSWORD_PS_PLUS=
# DB_HOST_PS_STORE=127.0.0.1
# DB_PORT_PS_STORE=3306
# DB_DATABASE_PS_STORE=
# DB_USERNAME_PS_STORE=
# DB_PASSWORD_PS_STORE=
# DB_HOST_1GROS_PROD=127.0.0.1
# DB_PORT_1GROS_PROD=3306
# DB_DATABASE_1GROS_PROD=
# DB_USERNAME_1GROS_PROD=
# DB_PASSWORD_1GROS_PROD=

# ==============================================================================
# 6. EXTERNAL SYSTEMS LAYER
# ==============================================================================
# External adapters provide transport and observations. They do not define meaning.

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Files / object storage
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Platform integrations
APP_WILDFLOW_URL=https://api.wildflow.dev/api/v1/
WILDFLOW_VERIFY_TLS=true
# APP_WILDFLOW_TOKEN=
# WILDFLOW_SKU_MAP_SHOP_IDS=1

DADATA_TOKEN=
IMGBB_API_KEY=

# Redeem local helper. Do not set in production.
# REDEEM_LOCAL_VERIFICATION_CODE=123456
# REDEEM_FALLBACK_WILDFLOW_PROVIDER_ID=

# Simple L1 / SL1E identity provider
SIMPLE_L1_IDENTITY_PROVIDER_URL=https://simplel1.online
SIMPLE_L1_PROTOCOL_GATEWAY_URL=https://api.wildflow.test
SIMPLE_L1_PROOF_INTROSPECTION_PATH=/api/sl1e/proofs/introspect
SIMPLE_L1_CLIENT_ID=meanly.one
SIMPLE_L1_CLIENT_NAME=Meanly
SIMPLE_L1_UI_THEME=neobrutalism
SIMPLE_L1_VERIFY_TLS=true

# Search Demand Intelligence adapters
GOOGLE_SEARCH_CONSOLE_BASE_URL=https://www.googleapis.com
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=

YANDEX_WEBMASTER_BASE_URL=https://api.webmaster.yandex.net
YANDEX_WEBMASTER_API_VERSION=v4
YANDEX_WEBMASTER_OAUTH_TOKEN=
YANDEX_WEBMASTER_USER_ID=
YANDEX_WEBMASTER_HOST_ID=

GOOGLE_SUGGEST_BASE_URL=https://suggestqueries.google.com/complete/search
YANDEX_SUGGEST_BASE_URL=https://suggest.yandex.com/suggest-ff.cgi

# Optional ads/search/social adapters
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_ACCESS_TOKEN=
BING_WEB_SEARCH_SUBSCRIPTION_KEY=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
YANDEX_DIRECT_OAUTH_TOKEN=
YANDEX_DIRECT_CLIENT_LOGIN=
SEARCHAPI_API_KEY=
META_GRAPH_ACCESS_TOKEN=
META_GRAPH_AD_ACCOUNT_ID=
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=
INDEXNOW_HOST=
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=

# Local / cloud LLM adapters
LLM_PROVIDER=local
LLM_FALLBACK_PROVIDERS=openai,anthropic,local
LLM_CLOUD_REQUIRED=false
LLM_TIMEOUT=60
LLM_REDACT_PROMPTS=true

OLLAMA_MODEL=gemma4
OLLAMA_URL=http://localhost:11434

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORGANIZATION=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_VERSION=2023-06-01

# Operational notifications
TG_TOKEN=
TG_CHAT_ID=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# Trusted hosts are infrastructure allowlists, not market meaning.
TRUSTED_HOSTS="${APP_DOMAIN},localhost,localhost:8000,meanly.test,meanly.one,www.meanly.one,marketplace.one,www.marketplace.one,meanly.ar,meanly.ru"

# Local remote asset rewriting for database dumps with absolute production URLs.
# APP_REWRITE_REMOTE_ASSETS=false
# APP_REMOTE_ASSET_HOSTS=marketplace.meanly.ru,www.marketplace.meanly.ru
APP_NAME=Meanly
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://meanly.one
APP_TIMEZONE=UTC
APP_DOMAIN=meanly.one
APP_PRODUCTION_DOMAIN=meanly.one
APP_PUBLIC_DOMAINS=meanly.one,www.meanly.one,meanly.test,meanly.ar,meanly.ru,www.meanly.ru,digitienda.ar,www.digitienda.ar,tsipruli.ge,www.tsipruli.ge,marketplace.one,www.marketplace.one
# Optional aliases for different market domains. These do not need to share a parent domain.
MARKET_GLOBAL_DOMAINS=meanly.one,www.meanly.one,meanly.test,marketplace.one,www.marketplace.one
MARKET_LATAM_AR_DOMAINS=meanly.ar,ar.marketplace.one,ar.marketplace.test,digitienda.ar,www.digitienda.ar
MARKET_RU_DOMAINS=meanly.ru,www.meanly.ru,ru.marketplace.one,ru.marketplace.test
MARKET_GE_DOMAINS=tsipruli.ge,www.tsipruli.ge

# Ссылки вида https://marketplace.meanly.ru/img/... в БД: на local по умолчанию переписываются на APP_URL (нужен файл в public/).
# APP_REWRITE_REMOTE_ASSETS=false
# APP_REMOTE_ASSET_HOSTS=marketplace.meanly.ru,www.marketplace.meanly.ru

# Только local: фиксированный код email на redeem (обход сессии/кэша). На проде не задавать.
# REDEEM_LOCAL_VERIFICATION_CODE=123456

# Redeem: второй Wildflow (providers.id с другим credentials.api_key). Пусто — только основной провайдер.
# REDEEM_FALLBACK_WILDFLOW_PROVIDER_ID=

# Filament: отдельные поддомены на проде (без https://, несколько через запятую). Пусто = панели на любом хосте (удобно для local).
# ADMIN_PANEL_DOMAIN=marketplace.example.com
# PARTNER_PANEL_DOMAIN=seller.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=host.1gros.ru
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

DB_HOST_PS_PLUS=localhost
DB_PORT_PS_PLUS=3306
DB_DATABASE_PS_PLUS=
DB_USERNAME_PS_PLUS=
DB_PASSWORD_PS_PLUS=

DB_HOST_PS_STORE=localhost
DB_PORT_PS_STORE=3306
DB_DATABASE_PS_STORE=
DB_USERNAME_PS_STORE=
DB_PASSWORD_PS_STORE=

DB_HOST_1GROS_PROD=localhost
DB_PORT_1GROS_PROD=3306
DB_DATABASE_1GROS_PROD=
DB_USERNAME_1GROS_PROD=
DB_PASSWORD_1GROS_PROD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Без SMTP: письма в storage/logs/laravel.log (ищите HTML с кодом)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

YM_API_KEY=
YM_BUSINESS_ID=
YM_CAMPAIGN_ID=
YM_CATEGORY_ID=
YM_NOTIFICATION_TOKEN=
YM_VERIFY_TLS=true

PS_TAX=35

# Добавьте поддомены админок и прод-витрину; для redeem используется объединённый список с ADMIN_PANEL_DOMAIN / PARTNER_PANEL_DOMAIN из config.
TRUSTED_HOSTS="${APP_DOMAIN},localhost,meanly.one,www.meanly.one,meanly.test,meanly.ar,meanly.ru,marketplace.one,www.marketplace.one"

TG_TOKEN=
TG_CHAT_ID=

# Wildflow parse: при смене SKU каталога обновить products у этих shop id (по умолчанию 1 = MEANLY).
# Production Wildflow API: https://api.wildflow.dev/api/v1/
# Local Valet/dev override: http://api.wildflow.test/api/v1/
APP_WILDFLOW_URL=https://api.wildflow.dev/api/v1/
WILDFLOW_VERIFY_TLS=true
# Provider credentials in DB must include api_key, client_id, and financial_secret.
# WILDFLOW_SKU_MAP_SHOP_IDS=1

# Simple L1 / SL1E Identity Provider
SIMPLE_L1_IDENTITY_PROVIDER_URL=https://simplel1.online
SIMPLE_L1_PROTOCOL_GATEWAY_URL=https://api.wildflow.test
SIMPLE_L1_PROOF_INTROSPECTION_PATH=/api/sl1e/proofs/introspect
SIMPLE_L1_CLIENT_ID=meanly.one
SIMPLE_L1_CLIENT_NAME=Meanly
SIMPLE_L1_UI_THEME=neobrutalism
# Keep TLS verification enabled outside explicit local-only debugging.
SIMPLE_L1_VERIFY_TLS=true

GOOGLE_TRANSLATE_API_KEY=

# Search Demand Intelligence external signal adapters
GOOGLE_SEARCH_CONSOLE_BASE_URL=https://www.googleapis.com
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=
YANDEX_WEBMASTER_BASE_URL=https://api.webmaster.yandex.net
YANDEX_WEBMASTER_API_VERSION=v4
YANDEX_WEBMASTER_OAUTH_TOKEN=
YANDEX_WEBMASTER_USER_ID=
YANDEX_WEBMASTER_HOST_ID=
GOOGLE_SUGGEST_BASE_URL=https://suggestqueries.google.com/complete/search
YANDEX_SUGGEST_BASE_URL=https://suggest.yandex.com/suggest-ff.cgi

OLLAMA_MODEL=gemma4
OLLAMA_URL=http://localhost:11434

# LLM provider layer: local Ollama by default, cloud providers can be enabled for prod.
LLM_PROVIDER=local
LLM_FALLBACK_PROVIDERS=openai,anthropic,local
LLM_CLOUD_REQUIRED=false
LLM_TIMEOUT=60
LLM_REDACT_PROMPTS=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORGANIZATION=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_VERSION=2023-06-01
