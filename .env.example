APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://1gros.local
APP_TIMEZONE=Europe/Moscow
APP_DOMAIN=1gros.local

# Ссылки вида https://marketplace.meanly.ru/img/... в БД: на local по умолчанию переписываются на APP_URL (нужен файл в public/).
# APP_REWRITE_REMOTE_ASSETS=false
# APP_REMOTE_ASSET_HOSTS=marketplace.meanly.ru,www.marketplace.meanly.ru

# Только local: фиксированный код email на redeem (обход сессии/кэша). На проде не задавать.
# REDEEM_LOCAL_VERIFICATION_CODE=123456

# Redeem: второй Wildflow (providers.id с другим credentials.api_key). Пусто — только основной провайдер.
# REDEEM_FALLBACK_WILDFLOW_PROVIDER_ID=

# Filament: отдельные поддомены на проде (без https://, несколько через запятую). Пусто = панели на любом хосте (удобно для local).
# ADMIN_PANEL_DOMAIN=marketplace.example.com
# PARTNER_PANEL_DOMAIN=seller.example.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=host.1gros.ru
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

DB_HOST_PS_PLUS=localhost
DB_PORT_PS_PLUS=3306
DB_DATABASE_PS_PLUS=
DB_USERNAME_PS_PLUS=
DB_PASSWORD_PS_PLUS=

DB_HOST_PS_STORE=localhost
DB_PORT_PS_STORE=3306
DB_DATABASE_PS_STORE=
DB_USERNAME_PS_STORE=
DB_PASSWORD_PS_STORE=

DB_HOST_1GROS_PROD=localhost
DB_PORT_1GROS_PROD=3306
DB_DATABASE_1GROS_PROD=
DB_USERNAME_1GROS_PROD=
DB_PASSWORD_1GROS_PROD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Без SMTP: письма в storage/logs/laravel.log (ищите HTML с кодом)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

YM_API_KEY=
YM_BUSINESS_ID=
YM_CAMPAIGN_ID=
YM_CATEGORY_ID=
YM_NOTIFICATION_TOKEN=
YM_VERIFY_TLS=true

PS_TAX=35

# Добавьте поддомены админок и прод-витрину; для redeem используется объединённый список с ADMIN_PANEL_DOMAIN / PARTNER_PANEL_DOMAIN из config.
TRUSTED_HOSTS="${APP_DOMAIN},localhost,marketplace.1gros.ru,1gros.ru,playstationplus.ru,ps-store.ru"

TG_TOKEN=
TG_CHAT_ID=

# Wildflow parse: при смене SKU каталога обновить products у этих shop id (по умолчанию 1 = MEANLY).
# Production Wildflow API: https://api.wildflow.dev/api/v1/
# Local Valet/dev override: http://api.wildflow.test/api/v1/
APP_WILDFLOW_URL=https://api.wildflow.dev/api/v1/
WILDFLOW_VERIFY_TLS=true
# Provider credentials in DB must include api_key, client_id, and financial_secret.
# WILDFLOW_SKU_MAP_SHOP_IDS=1

GOOGLE_TRANSLATE_API_KEY=

OLLAMA_MODEL=gemma4
OLLAMA_URL=http://localhost:11434

# LLM provider layer: local Ollama by default, cloud providers can be enabled for prod.
LLM_PROVIDER=local
LLM_FALLBACK_PROVIDERS=openai,anthropic,local
LLM_CLOUD_REQUIRED=false
LLM_TIMEOUT=60
LLM_REDACT_PROMPTS=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORGANIZATION=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_VERSION=2023-06-01
