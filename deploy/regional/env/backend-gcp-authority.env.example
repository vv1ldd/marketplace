# Global Laravel API — GCP ONE Authority (api.meanly.one on lena-1-gcl / ops-gcl).
# Merge with backend-gcp-global.env.example. No EZPIN_* on API — vendor keys on dgs-authority only.

APP_URL=https://api.meanly.one
APP_DOMAIN=api.meanly.one
APP_PUBLIC_DOMAINS=meanly.one,www.meanly.one,meanly.ru,www.meanly.ru,api.meanly.one

# Phase A — authority kernel (dgs-authority stack, not sterile edge)
DIGITAL_GOODS_SOURCE_URL=http://dgs-authority:8080/api/v1
WILDFLOW_KERNEL_MODE=http
WILDFLOW_FULFILLMENT_MODE=http
WILDFLOW_FORCE_DIRECT_SUPPLY=true
WILDFLOW_SPLIT_FULFILLMENT_PROVIDERS=ezpin-sandbox,ezpin
DGS_FULFILLMENT_URL=http://dgs-authority-node:8091
DGS_FULFILLMENT_TIMEOUT=60
DGS_SHADOW_INGEST_URL=http://dgs-authority-node:8092/shadow/ingest
# DIGITAL_GOODS_SOURCE_FINANCIAL_SECRET=<aligned-with-dgs-authority>
# APP_WILDFLOW_TOKEN=<X-Auth-Token for edge catalog mirror>

# Phase C cutover: WILDFLOW_FULFILLMENT_MODE=split (Node on dgs-authority-node with EzPin)
