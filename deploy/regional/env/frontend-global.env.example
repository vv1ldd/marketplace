# Coolify / Docker build env — global storefront (meanly.one)
# Same git repo and Dockerfile as RU; only env differs.

NEXT_PUBLIC_MARKETPLACE_API_URL=https://api.meanly.one
NEXT_PUBLIC_STOREFRONT_URL=https://meanly.one
NEXT_PUBLIC_SIMPLE_L1_URL=https://meanly.one
NEXT_PUBLIC_MARKETPLACE_REGION=global

NEXT_PUBLIC_ACQUIRING_COMPANY_BRAND=Meanly
NEXT_PUBLIC_ACQUIRING_COMPANY_LEGAL_NAME=Meanly Systems
NEXT_PUBLIC_ACQUIRING_COMPANY_COUNTRY=United States
NEXT_PUBLIC_ACQUIRING_COMPANY_EMAIL=support@meanly.one
NEXT_PUBLIC_ACQUIRING_SSL_LEVEL=TLS 1.2 or higher
NEXT_PUBLIC_ACQUIRING_PAYMENT_SYSTEMS=Visa,Mastercard,American Express
