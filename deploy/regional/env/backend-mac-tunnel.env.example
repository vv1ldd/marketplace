# Laravel .env overrides for Mac dev + meanly.one tunnel
# Apply with: ./scripts/regional-backend-env.sh tunnel-global

APP_URL=https://api.meanly.test
APP_DOMAIN=meanly.test

MARKET_DEFAULT=global
MARKET_GLOBAL_DOMAINS=meanly.one,www.meanly.one,meanly.test,marketplace.one,www.marketplace.one

STOREFRONT_FRONTEND_URL=https://meanly.one
STOREFRONT_ALLOWED_RETURN_ORIGINS=https://meanly.one,https://www.meanly.one,https://meanly.test,https://maestrooo.test,https://maestrooo.one
STOREFRONT_ALLOWED_ORIGINS=https://meanly.one,https://www.meanly.one,https://meanly.test
STOREFRONT_API_HOSTS=api.meanly.test

SIMPLE_L1_IDENTITY_PROVIDER_URL=https://meanly.one
SIMPLE_L1_PROTOCOL_GATEWAY_URL=https://meanly.one
# Local Simple L1 node (must be running on :3000). Proofs live here, not on meanly.one itself.
SIMPLE_L1_RUNTIME_URL=http://127.0.0.1:3000
# Registered SL1 OAuth client for local dev (redirect URIs must include meanly.one callback).
SIMPLE_L1_CLIENT_ID=meanly.test

SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# Managed Wallet — EVM rails on meanly.one tunnel
COMMERCE_CRYPTO_RAILS_ENABLED=true
MANAGED_WALLETS_ENABLED=true
MANAGED_WALLET_POLYGON_ENABLED=true
MANAGED_WALLET_ETHEREUM_ENABLED=true
MANAGED_WALLET_BASE_ENABLED=true
MANAGED_WALLET_BITCOIN_ENABLED=true
MANAGED_WALLET_SOLANA_ENABLED=true
MANAGED_WALLET_TON_ENABLED=true
SETTLEMENT_ADAPTER_POLYGON_ENABLED=true
SETTLEMENT_ADAPTER_POLYGON_MODE=read_only
SETTLEMENT_ADAPTER_ETHEREUM_ENABLED=true
SETTLEMENT_ADAPTER_ETHEREUM_MODE=read_only
SETTLEMENT_ADAPTER_BASE_ENABLED=true
SETTLEMENT_ADAPTER_BASE_MODE=read_only
POLYGON_RPC_ENABLED=true
ETHEREUM_RPC_ENABLED=true
BASE_RPC_ENABLED=true
