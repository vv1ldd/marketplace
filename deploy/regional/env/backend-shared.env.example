# Shared Laravel API — one backend for all regional frontends.
# Paste into the API service env in Coolify (not into Next builds).

APP_URL=https://api.meanly.one
APP_DOMAIN=api.meanly.one
APP_PUBLIC_DOMAINS=meanly.one,www.meanly.one,meanly.ru,www.meanly.ru,api.meanly.one

MARKET_DEFAULT=global
MARKET_GLOBAL_DOMAINS=meanly.one,www.meanly.one,marketplace.one,www.marketplace.one
MARKET_RU_DOMAINS=meanly.ru,www.meanly.ru,ru.marketplace.one
MARKET_LATAM_AR_DOMAINS=meanly.ar,digitienda.ar,www.digitienda.ar
MARKET_GE_DOMAINS=tsipruli.ge,www.tsipruli.ge

SESSION_DOMAIN=null

STOREFRONT_API_HOSTS=api.meanly.one
STOREFRONT_ALLOWED_ORIGINS=https://meanly.one,https://www.meanly.one,https://meanly.ru,https://www.meanly.ru
STOREFRONT_ALLOWED_RETURN_ORIGINS=https://meanly.one,https://meanly.ru
STOREFRONT_FRONTEND_URL=https://meanly.one
STOREFRONT_TOKEN_AUDIENCE=regional-frontends

SIMPLE_L1_IDENTITY_PROVIDER_URL=https://pass.simplelayer.one
SIMPLE_L1_PROTOCOL_GATEWAY_URL=https://pass.simplelayer.one
SIMPLE_L1_RUNTIME_URL=http://simple-l1:3000
SIMPLE_L1_IDENTITY_BROWSER_URL=https://meanly.one
SIMPLE_L1_CLIENT_ID=meanly.one

# Vault / SL1e stream authorize (storefront /authorize on meanly.one + meanly.ru)
IDENTITY_GOVERNANCE_STREAM_ENABLED=true
IDENTITY_GOVERNANCE_STREAM_AUTHORIZE_ENABLED=true

# Managed Wallet v0 — production API (Coolify)
COMMERCE_CRYPTO_RAILS_ENABLED=true
MANAGED_WALLETS_ENABLED=true
MANAGED_WALLETS_AUTO_PROVISION=true
MANAGED_WALLET_POLYGON_ENABLED=true
MANAGED_WALLET_ETHEREUM_ENABLED=true
MANAGED_WALLET_BASE_ENABLED=true
MANAGED_WALLET_BITCOIN_ENABLED=true
MANAGED_WALLET_SOLANA_ENABLED=true
MANAGED_WALLET_TON_ENABLED=true
SETTLEMENT_ADAPTER_POLYGON_ENABLED=true
SETTLEMENT_ADAPTER_POLYGON_MODE=full
SETTLEMENT_ADAPTER_ETHEREUM_ENABLED=true
SETTLEMENT_ADAPTER_ETHEREUM_MODE=full
SETTLEMENT_ADAPTER_BASE_ENABLED=true
SETTLEMENT_ADAPTER_BASE_MODE=full
POLYGON_RPC_ENABLED=true

TRUSTED_HOSTS=meanly.one,www.meanly.one,meanly.ru,www.meanly.ru,api.meanly.one

# Phase 4 — Wildflow fulfillment authority (lena DGS sidecar stack)
# Financial grant-credit stays on PHP digital-goods-source; vendor issue moves to Node in split/node.
DIGITAL_GOODS_SOURCE_URL=http://digital-goods-source:8080/api/v1
WILDFLOW_KERNEL_MODE=http
WILDFLOW_FULFILLMENT_MODE=split
WILDFLOW_SPLIT_FULFILLMENT_PROVIDERS=ezpin-sandbox,ezpin
WILDFLOW_FORCE_DIRECT_SUPPLY=true
DGS_FULFILLMENT_URL=http://dgs-node-sidecar:8091
DGS_FULFILLMENT_TIMEOUT=60
DGS_SHADOW_INGEST_URL=http://dgs-node-sidecar:8092/shadow/ingest
# DIGITAL_GOODS_SOURCE_FINANCIAL_SECRET=<aligned-with-php-kernel>
# DIGITAL_GOODS_SOURCE_PLATFORM_TOKEN=<aligned-with-php-kernel>
# EZPIN_* — digital-goods-sidecar only (ADR 0036). Do not set on Meanly API.

# Pre-GCP transitional (meanly.one still on lena, edge DGS sterile):
# WILDFLOW_FULFILLMENT_MODE=http
# Keep DGS_SHADOW_INGEST_URL for parity radar; omit DGS_FULFILLMENT_URL traffic (no split → Node).
