# Shared Laravel API — one backend for all regional frontends.
# Paste into the API service env in Coolify (not into Next builds).

APP_URL=https://api.meanly.one
APP_DOMAIN=api.meanly.one
APP_PUBLIC_DOMAINS=meanly.one,www.meanly.one,meanly.ru,www.meanly.ru,api.meanly.one

MARKET_DEFAULT=global
MARKET_GLOBAL_DOMAINS=meanly.one,www.meanly.one,marketplace.one,www.marketplace.one
MARKET_RU_DOMAINS=meanly.ru,www.meanly.ru,ru.marketplace.one
MARKET_LATAM_AR_DOMAINS=meanly.ar,digitienda.ar,www.digitienda.ar
MARKET_GE_DOMAINS=tsipruli.ge,www.tsipruli.ge

SESSION_DOMAIN=null

STOREFRONT_API_HOSTS=api.meanly.one
STOREFRONT_ALLOWED_ORIGINS=https://meanly.one,https://www.meanly.one,https://meanly.ru,https://www.meanly.ru
STOREFRONT_ALLOWED_RETURN_ORIGINS=https://meanly.one,https://meanly.ru
STOREFRONT_FRONTEND_URL=https://meanly.one
STOREFRONT_TOKEN_AUDIENCE=regional-frontends

SIMPLE_L1_IDENTITY_PROVIDER_URL=https://meanly.one
SIMPLE_L1_PROTOCOL_GATEWAY_URL=https://meanly.one
SIMPLE_L1_CLIENT_ID=meanly.one

TRUSTED_HOSTS=meanly.one,www.meanly.one,meanly.ru,www.meanly.ru,api.meanly.one
