# RU-sovereign Laravel API — lena only (api.meanly.ru).
# Paste into the RU API service env in Coolify on lena.

APP_URL=https://api.meanly.ru
APP_DOMAIN=api.meanly.ru
APP_PUBLIC_DOMAINS=meanly.ru,www.meanly.ru,api.meanly.ru

MARKET_DEFAULT=ru
MARKET_RU_DOMAINS=meanly.ru,www.meanly.ru,ru.marketplace.one
MARKET_GLOBAL_DOMAINS=meanly.one,www.meanly.one,marketplace.one

SESSION_DOMAIN=null

STOREFRONT_API_HOSTS=api.meanly.ru
STOREFRONT_ALLOWED_ORIGINS=https://meanly.ru,https://www.meanly.ru
STOREFRONT_ALLOWED_RETURN_ORIGINS=https://meanly.ru
STOREFRONT_FRONTEND_URL=https://meanly.ru
STOREFRONT_TOKEN_AUDIENCE=regional-frontends

# Internal RU sovereign issuer on lena (simple-l1-ru).
SIMPLE_L1_IDENTITY_PROVIDER_URL=https://pass.meanly.ru
SIMPLE_L1_PROTOCOL_GATEWAY_URL=https://pass.meanly.ru
SIMPLE_L1_RUNTIME_URL=https://pass.meanly.ru
SIMPLE_L1_IDENTITY_BROWSER_URL=https://meanly.ru
SIMPLE_L1_CLIENT_ID=meanly.ru

# ADR-0030 PAR -> connect.identity.meanly.ru
SIMPLE_L1_PAR_ENABLED_HOSTS=meanly.ru
SIMPLE_L1_PAR_ISSUER_BASE=https://pass.meanly.ru
SIMPLE_L1_PAR_CLIENT_SECRETS_JSON={"meanly.ru":"<secret-from-simple-l1-ru-registry>"}

IDENTITY_GOVERNANCE_STREAM_ENABLED=true
IDENTITY_GOVERNANCE_STREAM_AUTHORIZE_ENABLED=true

TRUSTED_HOSTS=meanly.ru,www.meanly.ru,api.meanly.ru

# RU supply contour: no direct EZPin/Fazer on lena. ONE (GCP) is sole upstream.
DIGITAL_GOODS_SOURCE_URL=https://api.meanly.one/api/v1
WILDFLOW_KERNEL_MODE=http
# Partner credentials issued by ONE via POST /api/v1/partners/sync (RU legal entity).
# DIGITAL_GOODS_SOURCE_FINANCIAL_SECRET=<from-one-partner-sync>
# Store api_key + client_id + financial_secret on the wildflow provider record in Ops.
