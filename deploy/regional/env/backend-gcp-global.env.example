# Global Laravel API — GCP ops-gcl (api.meanly.one).
# Issuer/ceremony stays on lena; API reaches simple-l1 over PUBLIC URLs.

APP_URL=https://api.meanly.one
APP_DOMAIN=api.meanly.one
APP_PUBLIC_DOMAINS=meanly.one,www.meanly.one,api.meanly.one

MARKET_DEFAULT=global
MARKET_GLOBAL_DOMAINS=meanly.one,www.meanly.one,marketplace.one,www.marketplace.one

SESSION_DOMAIN=null

STOREFRONT_API_HOSTS=api.meanly.one
STOREFRONT_ALLOWED_ORIGINS=https://meanly.one,https://www.meanly.one
STOREFRONT_ALLOWED_RETURN_ORIGINS=https://meanly.one
STOREFRONT_FRONTEND_URL=https://meanly.one
STOREFRONT_TOKEN_AUDIENCE=regional-frontends

SIMPLE_L1_IDENTITY_PROVIDER_URL=https://pass.meanly.one
SIMPLE_L1_PROTOCOL_GATEWAY_URL=https://pass.meanly.one
SIMPLE_L1_RUNTIME_URL=https://pass.meanly.one
SIMPLE_L1_IDENTITY_BROWSER_URL=https://meanly.one
SIMPLE_L1_CLIENT_ID=meanly.one

# ADR-0030: PAR + canonical ceremony origin (connect.identity.meanly.one).
SIMPLE_L1_PAR_ENABLED_HOSTS=meanly.one
SIMPLE_L1_PAR_ISSUER_BASE=https://pass.meanly.one
# Set secret from lena: /data/coolify/source/.par_secret_meanly_one
SIMPLE_L1_PAR_CLIENT_SECRETS_JSON={"meanly.one":"REPLACE_WITH_PAR_SECRET"}

IDENTITY_GOVERNANCE_STREAM_ENABLED=true
IDENTITY_GOVERNANCE_STREAM_AUTHORIZE_ENABLED=true

TRUSTED_HOSTS=meanly.one,www.meanly.one,api.meanly.one
