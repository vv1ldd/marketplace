# Copy to scripts/.beta-notify.env (gitignored) or export in shell.
#
# 1. Create a bot via @BotFather → /newbot → copy token.
# 2. Add the bot to your beta Telegram group (as admin if the group is private).
# 3. Send any message in the group, then run:
#      curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq .
#    Use chat.id (negative number for groups), e.g. -1001234567890.
#
MEANLY_BETA_TELEGRAM_BOT_TOKEN=
MEANLY_BETA_TELEGRAM_CHAT_ID=

# Optional overrides:
# MEANLY_DEV_PORT=3001
# MEANLY_DEV_TUNNEL_HOST=meanly.one
# MEANLY_SIMPLE_L1_PORT=3000
# MEANLY_BETA_NOTIFY_INTERVAL=15
# MEANLY_BETA_NOTIFY_STABLE_CHECKS=2
# MEANLY_BETA_NOTIFY_PUBLIC=1
