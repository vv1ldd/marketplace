FROM node:22-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

FROM node:22-alpine AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

ARG NEXT_PUBLIC_MARKETPLACE_API_URL=https://api.meanly.one
ARG NEXT_PUBLIC_STOREFRONT_URL=https://meanly.one
ARG NEXT_PUBLIC_SIMPLE_L1_URL=https://meanly.one
ARG NEXT_PUBLIC_MARKETPLACE_REGION=global
ARG NEXT_PUBLIC_ACQUIRING_COMPANY_BRAND=Meanly
ARG NEXT_PUBLIC_ACQUIRING_COMPANY_LEGAL_NAME=Meanly Systems
ARG NEXT_PUBLIC_ACQUIRING_COMPANY_COUNTRY=United States
ARG NEXT_PUBLIC_ACQUIRING_COMPANY_EMAIL=support@meanly.one
ARG NEXT_PUBLIC_ACQUIRING_COMPANY_INN=
ARG NEXT_PUBLIC_ACQUIRING_COMPANY_KPP=
ARG NEXT_PUBLIC_ACQUIRING_COMPANY_OGRN=
ARG NEXT_PUBLIC_ACQUIRING_BANK_NAME=
ARG NEXT_PUBLIC_ACQUIRING_SSL_LEVEL=TLS 1.2 or higher
ARG NEXT_PUBLIC_ACQUIRING_PAYMENT_SYSTEMS=Visa,Mastercard,American Express

ENV NEXT_PUBLIC_MARKETPLACE_API_URL=$NEXT_PUBLIC_MARKETPLACE_API_URL
ENV NEXT_PUBLIC_STOREFRONT_URL=$NEXT_PUBLIC_STOREFRONT_URL
ENV NEXT_PUBLIC_SIMPLE_L1_URL=$NEXT_PUBLIC_SIMPLE_L1_URL
ENV NEXT_PUBLIC_MARKETPLACE_REGION=$NEXT_PUBLIC_MARKETPLACE_REGION
ENV NEXT_PUBLIC_ACQUIRING_COMPANY_BRAND=$NEXT_PUBLIC_ACQUIRING_COMPANY_BRAND
ENV NEXT_PUBLIC_ACQUIRING_COMPANY_LEGAL_NAME=$NEXT_PUBLIC_ACQUIRING_COMPANY_LEGAL_NAME
ENV NEXT_PUBLIC_ACQUIRING_COMPANY_COUNTRY=$NEXT_PUBLIC_ACQUIRING_COMPANY_COUNTRY
ENV NEXT_PUBLIC_ACQUIRING_COMPANY_EMAIL=$NEXT_PUBLIC_ACQUIRING_COMPANY_EMAIL
ENV NEXT_PUBLIC_ACQUIRING_COMPANY_INN=$NEXT_PUBLIC_ACQUIRING_COMPANY_INN
ENV NEXT_PUBLIC_ACQUIRING_COMPANY_KPP=$NEXT_PUBLIC_ACQUIRING_COMPANY_KPP
ENV NEXT_PUBLIC_ACQUIRING_COMPANY_OGRN=$NEXT_PUBLIC_ACQUIRING_COMPANY_OGRN
ENV NEXT_PUBLIC_ACQUIRING_BANK_NAME=$NEXT_PUBLIC_ACQUIRING_BANK_NAME
ENV NEXT_PUBLIC_ACQUIRING_SSL_LEVEL=$NEXT_PUBLIC_ACQUIRING_SSL_LEVEL
ENV NEXT_PUBLIC_ACQUIRING_PAYMENT_SYSTEMS=$NEXT_PUBLIC_ACQUIRING_PAYMENT_SYSTEMS

COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000
CMD ["node", "server.js"]
